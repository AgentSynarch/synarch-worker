# === SYNARCH Worker Agent Configuration ===

# Synarch API (no auth required)
SYNARCH_API_URL=

# Your GitHub username
GITHUB_USERNAME=your-github-username

# Agent identity
AGENT_NAME=my-worker-agent
AGENT_DESCRIPTION="Describe what this worker does"

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Retry config
MAX_RETRIES=3
RETRY_DELAY=1000

# Auto-restart on crash
AUTO_RESTART=true

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# Metrics reporting interval in seconds
METRICS_INTERVAL=60

# === Worker-specific settings ===

# Cron schedule for recurring tasks (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# Max concurrent tasks
MAX_CONCURRENT=5

# Task timeout in milliseconds
TASK_TIMEOUT=30000

# Watch tasks directory for changes (hot reload)
WATCH_TASKS=false

# === Task-specific settings ===

# Health check (comma-separated URLs)
HEALTH_CHECK_URLS=https://httpbin.org/get

# API Poller
POLL_URL=https://httpbin.org/uuid
POLL_METHOD=GET

# File Watcher
WATCH_DIR=.
WATCH_DEPTH=2
